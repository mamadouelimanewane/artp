# ── Base de données ─────────────────────────────────────────────
# Dev local (SQLite)
DB_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Production Railway + Vercel Postgres
# DB_PROVIDER="postgresql"
# DATABASE_URL="postgresql://user:password@host:5432/dbname"

# ── JWT ─────────────────────────────────────────────────────────
JWT_SECRET="changeme_jwt_secret_artp_2026_very_long_random"
JWT_EXPIRES_IN="7d"

# ── API ─────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── SMS (Orange Senegal) ────────────────────────────────────────
SMS_PROVIDER=orange
ORANGE_API_KEY=your_orange_api_key

# ── Service IA ──────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001

# ── Uploads ─────────────────────────────────────────────────────
UPLOAD_DIR=./uploads

# ── Web Admin (Vercel) ──────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
