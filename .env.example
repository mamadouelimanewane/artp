# ── Base de données ────────────────────────────────────────────
DATABASE_URL="postgresql://artp:artp_secret@localhost:5432/artp_monreseau"
REDIS_URL="redis://localhost:6379"

# ── JWT ───────────────────────────────────────────────────────
JWT_SECRET="changeme_jwt_secret_artp_2026"
JWT_EXPIRES_IN="7d"
REFRESH_TOKEN_EXPIRES_IN="30d"

# ── API ───────────────────────────────────────────────────────
API_PORT=3001
NODE_ENV=development
API_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:5173

# ── SMS (Orange Senegal) ──────────────────────────────────────
SMS_PROVIDER=orange
ORANGE_API_KEY=your_orange_api_key
ORANGE_SENDER=ARTP

# ── Service IA ────────────────────────────────────────────────
AI_SERVICE_URL=http://localhost:8001
AI_SERVICE_KEY=changeme_ai_secret

# ── Uploads ───────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760

# ── Admin web ─────────────────────────────────────────────────
VITE_API_URL=http://localhost:3001/api
VITE_APP_NAME="Mon Réseau SN — ARTP"
